# ClickHouse connection (same as dbt-cerebro and cerebro-api)
CLICKHOUSE_HOST=ujt1j3jrk0.eu-central-1.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here
CLICKHOUSE_SECURE=True

# dbt manifest source (URL takes precedence over local path)
DBT_MANIFEST_URL=https://gnosischain.github.io/dbt-cerebro/manifest.json
# DBT_MANIFEST_PATH=./manifest.json

# Safety limits
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
MAX_QUERY_LENGTH=10000

# Thinking / tracing
THINKING_MODE_ENABLED=True
THINKING_ALWAYS_ON=True
THINKING_LOG_DIR=.cerebro/logs
THINKING_LOG_RETENTION_DAYS=30
